<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>a8473972-6583-4df4-b72a-56f556e9f059</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Storm Search</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Push to Apollo Sequence"/>
  <Description DefaultValue="Push your Outlook reply into an Apollo sequence so follow-ups continue automatically."/>
  <IconUrl DefaultValue="https://nicka2717.github.io/stormsearch-apollo-outlook-addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://nicka2717.github.io/stormsearch-apollo-outlook-addin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://github.com/NickA2717/stormsearch-apollo-outlook-addin"/>
  <AppDomains>
    <AppDomain>https://nicka2717.github.io</AppDomain>
    <AppDomain>https://api.apollo.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://nicka2717.github.io/stormsearch-apollo-outlook-addin/src/taskpane.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteMailbox</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="commandsUrl"/>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeGroup">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="msgComposeOpenPaneButton">
                  <Label resid="paneButtonLabel"/>
                  <Supertip>
                    <Title resid="paneButtonLabel"/>
                    <Description resid="paneButtonTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://nicka2717.github.io/stormsearch-apollo-outlook-addin/assets/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://nicka2717.github.io/stormsearch-apollo-outlook-addin/assets/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://nicka2717.github.io/stormsearch-apollo-outlook-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="commandsUrl" DefaultValue="https://nicka2717.github.io/stormsearch-apollo-outlook-addin/src/commands.html"/>
        <bt:Url id="taskpaneUrl" DefaultValue="https://nicka2717.github.io/stormsearch-apollo-outlook-addin/src/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Apollo"/>
        <bt:String id="paneButtonLabel" DefaultValue="Push to Apollo"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="paneButtonTooltip" DefaultValue="Push this reply into an Apollo sequence."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
